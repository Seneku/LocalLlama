{
  "name": "local-llama",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "tsc --noEmit && vite build",
    "build:standalone": "bun run build && bun run scripts/inline-frontend.ts",
    "start": "bun server/index.ts",
    "start:standalone": "bun run build:standalone && bun run server/standalone.ts",
    "package": "bun run build:standalone && bun build --compile --minify --outfile dist/LocalLlama.exe server/standalone.ts",
    "package:win": "bun build --compile --minify --target=bun-windows-x64 --outfile dist/LocalLlama-win-x64.exe server/standalone.ts",
    "package:linux": "bun build --compile --minify --target=bun-linux-x64 --outfile dist/LocalLlama-linux-x64 server/standalone.ts",
    "package:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 --outfile dist/LocalLlama-macos-arm64 server/standalone.ts",
    "package:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 --outfile dist/LocalLlama-macos-x64 server/standalone.ts",
    "package:all": "bun run build:standalone && bun run package:win && bun run package:linux && bun run package:macos-arm64 && bun run package:macos-x64",
    "restart": "scripts/restart-localllama.cmd",
    "test": "bun test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.10",
    "typescript": "^5.9.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9"
  }
}
